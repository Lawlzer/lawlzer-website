# Deployment Environment Variables
# Copy this file to .env.deployment and fill in the actual values

# AWS Configuration
AWS_REGION=us-east-1
STAGING_INSTANCE_ID=i-xxxxxxxxxxxxxxxxx

# MongoDB Configuration  
MONGO_SECRET_ARN=arn:aws:ssm:region:account-id:parameter/path/to/secret

# Application Configuration
APP_PORT=3000
APP_NAME=lawlzer-website-staging

# GitHub Configuration (for deployment)
GITHUB_ORG=Lawlzer
GITHUB_REPO=lawlzer-website
GITHUB_BRANCH=staging 